# --- Azure OpenAI ---
END_POINT=
AZURE_OPENAI_API_KEY=

# --- 모델 ---
MODEL_NAME=
MODEL_API_VERSION=

# --- Azure 구독 ---
AZURE_SUBSCRIPTION_ID=

# --- Azure UMI (User-assigned Managed Identity) ---
# Azure Portal > 관리 ID 리소스 > 클라이언트 ID
UMI_CLIENT_ID=

# Azure credentials (service principal — used when not running on Azure with managed identity)
# Leave blank to fall back to `az login` or managed identity (e.g. on Container Apps)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
